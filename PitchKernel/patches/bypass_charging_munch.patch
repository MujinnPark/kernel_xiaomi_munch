+/*
+ * smblib_bypass_band_work - software charge-band control.
+ *
+ * True PMIC power-path-independent bypass (powering the system from VBUS
+ * while leaving the battery FET open) could not be confirmed to exist on
+ * this board's SMB5 revision: POWER_PATH_STATUS_REG is read-only in this
+ * driver, and field testing showed that disabling charging via
+ * CHARGING_ENABLE_CMD_BIT (the only mechanism this driver exposes) simply
+ * halts input current rather than redirecting it - the device discharges
+ * normally instead of running off USB power.
+ *
+ * This holds capacity in [bypass_band_target - bypass_band_width,
+ * bypass_band_target] by toggling REAL charging on/off via the same
+ * BYPASS_VOTER vote the bypass_charging input_suspend path already uses.
+ * This does not power the device without touching the battery - it reduces
+ * time spent at high SoC under sustained load, which is what actually
+ * drives the heat/wear bypass charging is meant to address.
+ *
+ * Runs only while bypass_charging is active and USB is present; reschedules
+ * itself every 5s. Unplugging always clears the vote so charging is never
+ * left stuck disabled without a cable connected.
+ */
+static void smblib_bypass_band_work(struct work_struct *work)
+{
+	struct smb_charger *chg = container_of(work, struct smb_charger,
+			bypass_band_work.work);
+	union power_supply_propval pval = {0, };
+	int rc, capacity;
+
+	if (!bypass_charging)
+		return;
+
+	rc = smblib_get_prop_usb_present(chg, &pval);
+	if (rc < 0 || !pval.intval) {
+		/* not plugged in: never leave charging disabled */
+		if (bypass_band_holding) {
+			vote(chg->chg_disable_votable, BYPASS_VOTER, 0, 0);
+			bypass_band_holding = false;
+		}
+		schedule_delayed_work(&chg->bypass_band_work, 15 * HZ);
+		return;
+	}
+
+	rc = smblib_get_prop_batt_capacity(chg, &pval);
+	if (rc < 0) {
+		schedule_delayed_work(&chg->bypass_band_work, 5 * HZ);
+		return;
+	}
+	capacity = pval.intval;
+
+	if (!bypass_band_holding && capacity >= bypass_band_target) {
+		vote(chg->chg_disable_votable, BYPASS_VOTER, 1, 0);
+		bypass_band_holding = true;
+		smblib_dbg(chg, PR_MISC,
+			"bypass_band: cap=%d >= target=%d, holding\n",
+			capacity, bypass_band_target);
+	} else if (bypass_band_holding &&
+			capacity <= (bypass_band_target - bypass_band_width)) {
+		vote(chg->chg_disable_votable, BYPASS_VOTER, 0, 0);
+		bypass_band_holding = false;
+		smblib_dbg(chg, PR_MISC,
+			"bypass_band: cap=%d <= %d, resuming charge\n",
+			capacity, bypass_band_target - bypass_band_width);
+	}
+
+	schedule_delayed_work(&chg->bypass_band_work, 5 * HZ);
+}
