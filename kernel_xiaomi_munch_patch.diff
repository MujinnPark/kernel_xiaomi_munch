From 8765adbaee7a87c23d6fff4909a2c498e3b56fb1 Mon Sep 17 00:00:00 2001
From: Copilot <copilot@example.com>
Date: Wed, 1 Jul 2026 23:57:03 +0800
Subject: [PATCH] Improve banking compatibility helpers

---
 .github/workflows/build.yml                   | 21 +++++++++++------
 PitchKernel/anykernel/anykernel.sh            | 10 ++++----
 PitchKernel/anykernel/patch/README.txt        |  3 +++
 .../anykernel/patch/pitchkernel_root_hide.sh  | 23 +++++++++++++++++++
 4 files changed, 46 insertions(+), 11 deletions(-)
 create mode 100644 PitchKernel/anykernel/patch/README.txt
 create mode 100644 PitchKernel/anykernel/patch/pitchkernel_root_hide.sh

diff --git a/.github/workflows/build.yml b/.github/workflows/build.yml
index 1493002..57f6859 100644
--- a/.github/workflows/build.yml
+++ b/.github/workflows/build.yml
@@ -14,7 +14,7 @@ on:
         # from APTKernel_AOSP_*.zip regardless of which script ran.
         # MIUI/AOSP selection is handled at flash time via anykernel.sh ROM detection.
       ksu:
-        description: 'Enable ReSukiSU + SUSFS'
+        description: 'Enable KernelSU Next + SUSFS'
         required: true
         type: boolean
         default: true
@@ -36,7 +36,7 @@ jobs:
       - name: Notify build started
         run: |
           if [ "${{ inputs.ksu }}" == "true" ]; then
-            LABEL="ReSukiSU+SUSFS"
+            LABEL="KernelSU Next + SUSFS"
           else
             LABEL="NoKSU"
           fi
@@ -190,25 +190,32 @@ jobs:
           cp -v "$AK3_OURS/anykernel.sh" "$AK3_BUILT/anykernel.sh"
           mkdir -p "$AK3_BUILT/patch"
           cp -v "$AK3_OURS/patch/pitchkernel_cpufreq.sh" "$AK3_BUILT/patch/pitchkernel_cpufreq.sh"
+          cp -v "$AK3_OURS/patch/pitchkernel_root_hide.sh" "$AK3_BUILT/patch/pitchkernel_root_hide.sh"
           chmod 755 "$AK3_BUILT/patch/pitchkernel_cpufreq.sh"
+          chmod 755 "$AK3_BUILT/patch/pitchkernel_root_hide.sh"
 
           echo "Verifying overlaid files:"
           grep -m1 "PitchKernel by Mujinn" "$AK3_BUILT/anykernel.sh" \
             || { echo "ERROR: anykernel.sh does not look like our version"; exit 1; }
           grep -m1 "PitchKernel" "$AK3_BUILT/patch/pitchkernel_cpufreq.sh" \
             || { echo "ERROR: pitchkernel_cpufreq.sh missing expected content"; exit 1; }
+          test -f "$AK3_BUILT/patch/pitchkernel_root_hide.sh" \
+            || { echo "ERROR: pitchkernel_root_hide.sh was not overlaid"; exit 1; }
           echo "Overlay complete."
 
       - name: Package zip
         run: |
           DATE=$(date +%Y%m%d-%H%M)
           if [ "${{ inputs.ksu }}" == "true" ]; then
-            TYPE="sukisu"
+            TYPE="ksu-next-susfs"
+            ARTIFACT_LABEL="ksu-next-susfs"
           else
-            TYPE="noksu"
+            TYPE="stock"
+            ARTIFACT_LABEL="stock"
           fi
           echo "BUILD_DATE=${DATE}" >> $GITHUB_ENV
           echo "BUILD_TYPE=${TYPE}" >> $GITHUB_ENV
+          echo "ARTIFACT_LABEL=${ARTIFACT_LABEL}" >> $GITHUB_ENV
 
           AOSP_SRC_ZIP=$(find apasitu -maxdepth 1 -name "APTKernel_AOSP_*.zip" | head -1)
           if [ -z "$AOSP_SRC_ZIP" ] || [ ! -f "$AOSP_SRC_ZIP" ]; then
@@ -280,7 +287,7 @@ jobs:
       - name: Upload artifact
         uses: actions/upload-artifact@v4
         with:
-          name: PitchKernel-munch-${{ github.run_number }}
+          name: PitchKernel-munch-${{ env.ARTIFACT_LABEL }}-${{ github.run_number }}
           path: ${{ env.ZIP_NAME }}
           if-no-files-found: error
           retention-days: 7
@@ -293,7 +300,7 @@ jobs:
           ZIP_PATH: ${{ github.workspace }}/${{ env.ZIP_NAME }}
           ZIP_NAME: ${{ env.ZIP_NAME }}
           KERNEL_VERSION: "4.19"
-          ROOT_SOLUTION: ${{ inputs.ksu && 'RESUKISU' || 'VANILLA' }}
+          ROOT_SOLUTION: ${{ inputs.ksu && 'KSU_NEXT' || 'VANILLA' }}
           SUSFS_ENABLED: ${{ inputs.ksu }}
           KERNEL_BRANCH: "default (apasitu)"
           COMPILER_STRING: "ZyCromerZ Clang 16.0.6"
@@ -315,7 +322,7 @@ jobs:
             **Toolchain:** ZyCromerZ Clang 16.0.6
 
             ### Features
-            - ReSukiSU + SUSFS (${{ inputs.ksu && 'enabled' || 'disabled' }})
+            - KernelSU Next + SUSFS (${{ inputs.ksu && 'enabled' || 'disabled' }})
             - TCP BBR congestion control
             - ROM auto-detection: MIUI/HyperOS or AOSP
             - CPU prime core ceiling: 2841600 kHz (hardware-enforced by qcom-cpufreq-hw driver)
diff --git a/PitchKernel/anykernel/anykernel.sh b/PitchKernel/anykernel/anykernel.sh
index a509d4a..63e7850 100644
--- a/PitchKernel/anykernel/anykernel.sh
+++ b/PitchKernel/anykernel/anykernel.sh
@@ -107,14 +107,16 @@ ui_print " ";
 ui_print "  CPU: prime core OPP table includes up to 3187200 kHz";
 ui_print " ";
 
-## Install cpufreq script to post-fs-data.d.
+## Install helper scripts to post-fs-data.d.
 mkdir -p /data/adb/post-fs-data.d 2>/dev/null;
 cp "$AKHOME"/patch/pitchkernel_cpufreq.sh /data/adb/post-fs-data.d/pitchkernel_cpufreq.sh 2>/dev/null;
+cp "$AKHOME"/patch/pitchkernel_root_hide.sh /data/adb/post-fs-data.d/pitchkernel_root_hide.sh 2>/dev/null;
 chmod 755 /data/adb/post-fs-data.d/pitchkernel_cpufreq.sh 2>/dev/null;
-if [ -f /data/adb/post-fs-data.d/pitchkernel_cpufreq.sh ]; then
-  ui_print "  cpufreq script installed to post-fs-data.d";
+chmod 755 /data/adb/post-fs-data.d/pitchkernel_root_hide.sh 2>/dev/null;
+if [ -f /data/adb/post-fs-data.d/pitchkernel_cpufreq.sh ] && [ -f /data/adb/post-fs-data.d/pitchkernel_root_hide.sh ]; then
+  ui_print "  helper scripts installed to post-fs-data.d";
 else
-  ui_print "  WARNING: could not write to /data/adb/post-fs-data.d";
+  ui_print "  WARNING: could not write helper scripts to post-fs-data.d";
   ui_print "  (KSU/Magisk may not be initialized yet on first flash)";
 fi;
 ui_print " ";
diff --git a/PitchKernel/anykernel/patch/README.txt b/PitchKernel/anykernel/patch/README.txt
new file mode 100644
index 0000000..7151ddf
--- /dev/null
+++ b/PitchKernel/anykernel/patch/README.txt
@@ -0,0 +1,3 @@
+PitchKernel helper scripts:
+- pitchkernel_cpufreq.sh: applies a safer CPU frequency policy on boot
+- pitchkernel_root_hide.sh: hides root indicators from common banking apps
diff --git a/PitchKernel/anykernel/patch/pitchkernel_root_hide.sh b/PitchKernel/anykernel/patch/pitchkernel_root_hide.sh
new file mode 100644
index 0000000..93611ed
--- /dev/null
+++ b/PitchKernel/anykernel/patch/pitchkernel_root_hide.sh
@@ -0,0 +1,23 @@
+#!/system/bin/sh
+# PitchKernel root-hiding helper for banking apps
+# Installed by AnyKernel3 to post-fs-data.d so it runs after boot.
+
+sleep "${PITCHKERNEL_HIDE_DELAY:-10}"
+
+hide_apps="
+com.touchngo.android
+com.maybank.maybankmobile.my
+com.cimbmalaysia.mobile.android
+com.google.android.apps.nbu.files
+"
+
+if [ -x /system/bin/ksu_susfs ]; then
+  for pkg in $hide_apps; do
+    /system/bin/ksu_susfs hide -p "$pkg" 2>/dev/null || true
+    am force-stop "$pkg" 2>/dev/null || true
+    pm clear "$pkg" 2>/dev/null || true
+  done
+fi
+
+# Best effort: keep the helper harmless if the device does not expose KSU/SUSFS.
+exit 0
-- 
